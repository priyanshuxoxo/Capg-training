  "item": [
    {
      "name": "Put Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.globals.set(\"BaseUrl\", \"https://petstore3.swagger.io/api/v3\");\r",
              "\r",
              "pm.test(\"Your test name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.value).to.eql(100);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"id\" : {{petId}},\r\n    \"name\" : \"Ashleel Rapper\",\r\n    \"photoUrls\" : [{{img}}]\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BaseUrl}}/pet",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "pet"
          ]
        }
      },
      "response": []
    },
